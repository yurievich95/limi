---
layout: base.njk
title: Home
---

<style>
.hero {
  min-height: calc(100vh - var(--nav-height));
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.hero-left {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 5rem 3rem 5rem;
}
.hero-issue {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--rust);
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 1rem;
}
.hero-issue::before {
  content: '';
  display: block;
  width: 30px;
  height: 1px;
  background: var(--rust);
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(3.5rem, 7vw, 6.5rem);
  font-weight: 900;
  line-height: 0.92;
  letter-spacing: -0.03em;
  margin-bottom: 2rem;
}
.hero-title em { color: var(--rust); font-style: italic; }
.hero-subtitle {
  font-size: 1.5rem;
  font-weight: 300;
  font-style: italic;
  line-height: 1.65;
  opacity: 0.65;
  max-width: 380px;
  margin-bottom: 3rem;
}
.hero-right {
  background:
    radial-gradient(ellipse 60% 80% at 60% 40%, rgba(184,75,42,0.12) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 30% 70%, rgba(200,169,110,0.08) 0%, transparent 60%),
    linear-gradient(160deg, var(--fog) 0%, var(--cream) 50%, #EAE3D5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  flex-direction: column;
  padding: 3rem;
  gap: 0;
}
.cover-art {
  position: relative;
  width: 360px;
  height: 500px;
}
.cover-art::before {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 250px; height: 310px;
  border: 3.5px solid rgba(26,20,16,0.18);
  animation: drift 5s ease-in-out infinite;
}
.cover-art::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%) rotate(10deg);
  width: 250px; height: 310px;
  border: 3.5px solid rgba(184,75,42,0.35);
  animation: drift 8s ease-in-out infinite reverse;
}
.cover-fill {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  width: 120px; height: 160px;
  background: var(--rust);
  opacity: 0.07;
  animation: breathe 6s ease-in-out infinite;
}
.cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.7;
}

/* NB da rimuovere opacità 0 */
.cover-num {
  position: absolute;
  bottom: 0; right: 0;
  font-family: var(--font-display);
  font-size: 7rem;
  font-weight: 900;
  color: rgba(26,20,16,0.05);
  line-height: 1;
  opacity: 0.0;
}

/* NB da rimuovere opacità 0 */
.cover-theme-label {
  position: absolute;
  bottom: 2rem; left: 0;
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-style: italic;
  color: var(--ink);
  opacity: 0.0;
}
.cover-side-label {
  position: absolute;
  top: 2rem; left: -1.5rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--rust);
  writing-mode: vertical-rl;
}
@keyframes drift {
  0%,100% { transform: translate(-50%,-50%) rotate(0deg); }
  33% { transform: translate(-48%,-52%) rotate(3deg); }
  66% { transform: translate(-52%,-48%) rotate(-2deg); }
}
@keyframes breathe {
  0%,100% { transform: translate(-50%,-50%) scale(1); opacity: 0.07; }
  50% { transform: translate(-50%,-50%) scale(1.15); opacity: 0.12; }
}
.home-articles { padding: 5rem 0; }
.articles-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 1.5px;
}
.card-featured {
  grid-row: span 2;
  min-height: 380px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.card-featured .card-title { font-size: 1.9rem; font-weight: 700; }
.home-gallery { background: var(--deep); padding: 5rem 0; }
.home-gallery .section-title { color: var(--cream); }
.home-gallery .section-link { color: var(--gold); border-color: var(--gold); }
.gallery-grid-home {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5px;
}
.home-rubriche { padding: 5rem 0; }
.rubriche-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3rem;
  margin-top: 2.5rem;
}
.rubrica-item { border-top: 1px solid rgba(26,20,16,0.15); padding-top: 1.5rem; }
.rubrica-n {
  font-family: var(--font-display);
  font-size: 3.5rem;
  font-weight: 900;
  color: rgba(26,20,16,0.06);
  line-height: 1;
  margin-bottom: 0.5rem;
}
.rubrica-name {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--rust);
  margin-bottom: 0.4rem;
}
.rubrica-title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-style: italic;
  margin-bottom: 0.8rem;
  line-height: 1.3;
}
.rubrica-desc { font-size: 0.9rem; line-height: 1.65; opacity: 0.55; }
.home-cta {
  background: var(--rust);
  padding: 6rem 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.home-cta::before {
  content: 'LIMI.';
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  font-family: var(--font-display);
  font-size: 18vw;
  font-weight: 900;
  color: rgba(245,240,232,0.06);
  pointer-events: none;
  white-space: nowrap;
}
.home-cta-label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(245,240,232,0.55);
  margin-bottom: 1.5rem;
  position: relative;
}
.home-cta-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 900;
  color: var(--cream);
  margin-bottom: 1rem;
  position: relative;
}
.home-cta-sub {
  font-size: 1.1rem;
  font-style: italic;
  color: rgba(245,240,232,0.7);
  max-width: 480px;
  margin: 0 auto 2.5rem;
  line-height: 1.7;
  position: relative;
}
.btn-cream { color: var(--rust); background: var(--cream); position: relative; }
.btn-cream:hover { background: var(--ink); color: var(--cream); }
@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; }
  .hero-right { display: none; }
  .articles-grid { grid-template-columns: 1fr; }
  .card-featured { grid-row: auto; }
  .gallery-grid-home { grid-template-columns: repeat(2,1fr); }
  .rubriche-list { grid-template-columns: 1fr; }
}
</style>

{# ── Numero corrente con valori di fallback sicuri ── #}
{% if collections.numeri and collections.numeri.length > 0 %}
  {% set nc = collections.numeri[0] %}
  {% set nSlug     = nc.data.slug     if nc.data.slug     else "#" %}
  {% set nNumero   = nc.data.numero   if nc.data.numero   else 0 %}
  {% set nTema     = nc.data.tema     if nc.data.tema     else "In arrivo" %}
  {% set nAnno     = nc.data.anno     if nc.data.anno     else "" %}
  {% set nCover    = nc.data.copertina if nc.data.copertina else "" %}
  {% set nPdf      = nc.data.pdf      if nc.data.pdf      else "" %}
  {% set nProssimo = nNumero + 1 %}
  {% set nNumStr   = "" ~ nNumero %}
{% else %}
  {% set nc        = null %}
  {% set nSlug     = "#" %}
  {% set nNumero   = 0 %}
  {% set nNumStr   = "—" %}
  {% set nTema     = "In arrivo" %}
  {% set nAnno     = "" %}
  {% set nCover    = "" %}
  {% set nPdf      = "" %}
  {% set nProssimo = "" %}
{% endif %}

{# ── Articoli: prima prova per numero corrente, poi fallback su tutti ── #}
{% set articoliNumero = collections.articoli | byNumero(nNumStr) %}
{% if not articoliNumero or articoliNumero.length == 0 %}
  {% set articoliNumero = collections.articoli %}
{% endif %}

{# ── Galleria: stessa logica ── #}
{% set galleriaNumero = collections.galleria | byNumero(nNumStr) %}
{% if not galleriaNumero or galleriaNumero.length == 0 %}
  {% set galleriaNumero = collections.galleria %}
{% endif %}

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-issue">N° {{ nNumStr }} — {{ nTema }}{% if nAnno %} — {{ nAnno }}{% endif %}</div>
    <h1 class="hero-title">tra il<br><em>conosciuto</em><br>e l'ignoto.</h1>
    <p class="hero-subtitle">{{ siteDescription if siteDescription else "rivista online bimestrale con l'obiettivo di creare uno spazio di esposizione e condivisione per tutta." }}</p>
  </div>
  <div class="hero-right">
    <div class="cover-art">
      {% if nCover %}
        <img src="{{ nCover }}" alt="Copertina {{ nTema }}" class="cover-img">
      {% else %}
        <div class="cover-fill"></div>
      {% endif %}
      <div class="cover-num">{{ nNumStr }}</div>
      <div class="cover-side-label">Limi. Magazine</div>
      <div class="cover-theme-label">{{ nTema }}</div>
    </div>
{% if nPdf %}
  <a href="{{ nPdf }}" target="_blank"
     style="margin-top:2rem;display:block;text-align:center;text-decoration:none;font-family:var(--font-display);font-size:1.4rem;font-style:italic;font-weight:700;color:var(--rust);letter-spacing:-0.01em;transition:opacity 0.2s;border-bottom:2px solid var(--rust);padding-bottom:0.3rem;width:fit-content;margin-left:auto;margin-right:auto;"
     onmouseover="this.style.opacity='0.6';"
     onmouseout="this.style.opacity='1';">
    leggi ultimo numero
  </a>
{% else %}
  <a href="/numeri/{{ nSlug }}/"
     style="margin-top:2rem;display:block;text-align:center;text-decoration:none;font-family:var(--font-display);font-size:1.4rem;font-style:italic;font-weight:700;color:var(--rust);letter-spacing:-0.01em;transition:opacity 0.2s;border-bottom:2px solid var(--rust);padding-bottom:0.3rem;width:fit-content;margin-left:auto;margin-right:auto;"
     onmouseover="this.style.opacity='0.6';"
     onmouseout="this.style.opacity='1';">
    leggi ultimo numero
  </a>
{% endif %}
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-wrap">
  <div class="marquee-track">
    {% for i in [1, 2] %}
      {% for item in marquee.voci %}
        <span class="marquee-item">{{ item }}</span>
        <span class="marquee-item marquee-dot">◆</span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

<!-- ARTICOLI IN EVIDENZA -->
<section class="home-articles">
<div style="margin-bottom:2.5rem;">
  <div style="font-family:var(--font-mono);font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--rust);margin-bottom:0.8rem;display:flex;align-items:center;gap:1rem;">
    <span style="display:block;width:30px;height:1px;background:var(--rust);"></span>
    N° {{ nNumStr }} — {{ nTema }}
  </div>
  <div style="display:flex;align-items:baseline;justify-content:space-between;">
    <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:900;letter-spacing:-0.02em;">dal numero <em style="color:var(--rust);font-style:italic;">corrente</em></h2>
    <a href="/articoli/" class="section-link">Tutti gli articoli</a>
  </div>
</div>
    <div class="articles-grid">
      {% if articoliNumero and articoliNumero.length > 0 %}
        {% for articolo in articoliNumero.slice(0, 5) %}
          <a href="{{ articolo.url }}" class="card reveal {% if loop.first %}card-dark card-featured{% elif loop.index == 3 %}card-rust{% endif %}" style="position:relative;overflow:hidden;">
            {% if articolo.data.immagine %}
  <img src="{{ articolo.data.immagine }}" alt="{{ articolo.data.title }}"
       style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.35;pointer-events:none;z-index:0;">
  <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(26,20,16,0.75) 0%, rgba(26,20,16,0.1) 60%, transparent 100%);z-index:0;pointer-events:none;"></div>
{% endif %}
            <div style="position:relative;z-index:1;">
  <div class="card-label">{{ articolo.data.categoria }} — N°{{ articolo.data.numero }}</div>
  <div style="font-family:var(--font-display);font-size:1.35rem;font-weight:700;line-height:1.2;margin-bottom:0.6rem;letter-spacing:-0.01em;">
    {{ articolo.data.title }}
  </div>
  {% if articolo.data.excerpt %}
    <div style="font-family:var(--font-body);font-size:0.95rem;font-style:italic;font-weight:300;line-height:1.6;opacity:0.75;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
      {{ articolo.data.excerpt }}
    </div>
  {% endif %}
</div>
            <div style="position:relative;z-index:1;display:flex;justify-content:space-between;align-items:center;margin-top:1.2rem;padding-top:0.8rem;border-top:1px solid rgba(255,255,255,0.15);">
  {% if articolo.data.autore %}
    <span style="font-family:var(--font-mono);font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;background:rgba(255,255,255,0.12);padding:0.25rem 0.6rem;backdrop-filter:blur(4px);">
      {{ articolo.data.autore }}
    </span>
  {% else %}
    <span></span>
  {% endif %}
  <span style="font-size:0.9rem;opacity:0.5;">↗</span>
</div>
          </a>
        {% endfor %}
      {% else %}
        <a href="#" class="card card-dark card-featured reveal">
          <div class="card-label">Prosa — N°{{ nNumStr }}</div>
          <div class="card-title">Titolo dell'articolo in evidenza</div>
          <div class="card-excerpt">Incipit dell'articolo che cattura il lettore...</div>
          <div class="card-arrow">↗</div>
        </a>
        <a href="#" class="card reveal">
          <div class="card-label">Prosa — N°{{ nNumStr }}</div>
          <div class="card-title">Secondo articolo del numero</div>
          <div class="card-arrow">↗</div>
        </a>
        <a href="#" class="card card-rust reveal">
          <div class="card-label">Rubrica — N°{{ nNumStr }}</div>
          <div class="card-title">Articolo dalla rubrica fissa</div>
          <div class="card-arrow">↗</div>
        </a>
        <a href="#" class="card reveal">
          <div class="card-label">Saggio — N°{{ nNumStr }}</div>
          <div class="card-title">Quarto articolo del numero</div>
          <div class="card-arrow">↗</div>
        </a>
        <a href="#" class="card reveal">
          <div class="card-label">Poesia — N°{{ nNumStr }}</div>
          <div class="card-title">Quinto articolo del numero</div>
          <div class="card-arrow">↗</div>
        </a>
      {% endif %}
    </div>
  </div>
</section>

<!-- GALLERIA -->
<section class="home-gallery">
  <div class="container">
    <div class="section-header">
      <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:900;letter-spacing:-0.02em;color:var(--cream);">galleria di <em style="color:var(--gold);font-style:italic;">Limi.</em></h2>
      <a href="/galleria/" class="section-link">Tutta la galleria</a>
    </div>
    <div class="gallery-grid-home">
      {% if galleriaNumero and galleriaNumero.length > 0 %}
        {% for opera in galleriaNumero.slice(0,4) %}
          <a href="/galleria/" class="gallery-item reveal">
            {% if opera.data.image %}
              <img src="{{ opera.data.image }}" alt="{{ opera.data.title }}">
            {% else %}
              <div style="width:100%;height:100%;min-height:200px;background:linear-gradient({{ [135,160,200,220][loop.index0] }}deg,var(--deep) 0%,var(--rust) 60%,var(--gold) 100%);"></div>
            {% endif %}
          <div class="gallery-overlay" style="background:linear-gradient(to top, rgba(26,20,16,0.95) 0%, rgba(26,20,16,0.6) 50%, transparent 100%);padding:2rem 1.5rem;">
  <div style="font-family:var(--font-display);font-size:1.6rem;font-style:italic;font-weight:700;color:var(--cream);line-height:1.1;margin-bottom:0.8rem;text-shadow:0 2px 8px rgba(0,0,0,0.5);">
    {{ opera.data.title }}
  </div>
  {% if opera.data.autore %}
    <div style="font-family:var(--font-mono);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);text-shadow:0 1px 4px rgba(0,0,0,0.8);">
      {{ opera.data.autore }}
    </div>
  {% endif %}
</div>
          </a>
        {% endfor %}
      {% else %}
        {% for i in [1,2,3,4] %}
        <div class="gallery-item reveal" style="background:linear-gradient({{ [135,160,200,220][loop.index0] }}deg,var(--deep) 0%,var(--rust) 60%,var(--gold) 100%);">
          <div class="gallery-overlay">
            <div class="gallery-artist">Illustrazione</div>
            <div class="gallery-title">Opera N°{{ i }} — {{ nTema }}</div>
          </div>
        </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<!-- RUBRICHE -->
<section class="home-rubriche">
  <div class="container">
    <div class="section-header">
      <h2 style="font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:900;letter-spacing:-0.02em;color:var(--ink);">rubriche di <em style="color:var(--rust);font-style:italic;">Limi.</em></h2>
      <a href="/rubriche/" class="section-link">Tutte le rubriche</a>
    </div>
    <div class="rubriche-list">
      {% if collections.rubriche and collections.rubriche.length > 0 %}
        {% for rubrica in collections.rubriche %}
          <a href="{{ rubrica.url }}" class="rubrica-item reveal" style="text-decoration:none;color:inherit;">
            <div class="rubrica-n">{{ loop.index | string | padStart(2, '0') }}</div>
            <div class="rubrica-name">Rubrica fissa</div>
            <div class="rubrica-title">{{ rubrica.data.title }}</div>
            <div class="rubrica-desc">{{ rubrica.data.descrizione }}</div>
{% if rubrica.data.autore %}
  <div style="font-family:var(--font-mono);font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--rust);margin-top:1rem;padding-top:0.8rem;border-top:1px solid rgba(26,20,16,0.1);">
    {{ rubrica.data.autore }}
  </div>
{% endif %}
          </a>
        {% endfor %}
      {% else %}
        <div class="rubrica-item reveal">
          <div class="rubrica-n">01</div>
          <div class="rubrica-name">Rubrica fissa</div>
          <div class="rubrica-title">In Limine</div>
          <div class="rubrica-desc">Sulla soglia. Un diario che si forza di tenere, un esercizio di resistenza contro lo sconforto.</div>
        </div>
        <div class="rubrica-item reveal">
          <div class="rubrica-n">02</div>
          <div class="rubrica-name">Rubrica fissa</div>
          <div class="rubrica-title">Parole al Centro</div>
          <div class="rubrica-desc">La parola ricentrata nelle sue radici profonde — entità mobile in continua evoluzione.</div>
        </div>
        <div class="rubrica-item reveal">
          <div class="rubrica-n">03</div>
          <div class="rubrica-name">Rubrica fissa</div>
          <div class="rubrica-title">Pennellate al Microscopio</div>
          <div class="rubrica-desc">Arte e scienza in controluce. Pensatori di nicchia attraverso un'analisi emotiva e sensoriale.</div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- COLLABORA CTA -->
<section class="home-cta">
  {% if nProssimo %}
    <div class="home-cta-label">Numero {{ nProssimo }} — aperto alle collaborazioni</div>
  {% else %}
    <div class="home-cta-label">Prossimo numero — aperto alle collaborazioni</div>
  {% endif %}
  <h2 class="home-cta-title">Vorresti partecipare?</h2>
  <p class="home-cta-sub">Siamo aperti a scrittori, illustratori, fotografi, poeti. Se hai qualcosa da dire nello spazio del confine, vogliamo sentirti.</p>
  <a href="/collabora/" class="btn btn-cream">Scrivici</a>
</section>
