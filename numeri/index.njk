---
layout: base.njk
title: Numeri
description: Archivio di tutti i numeri di LIMI. Magazine.
---
<style>
.numeri-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-top: 3rem;
  padding-bottom: 6rem;
}
.numero-card {
  background: var(--fog);
  padding: 3rem 2.5rem;
  position: relative;
  overflow: hidden;
  min-height: 300px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  transition: background 0.3s;
}
.numero-card:hover { background: #C8C1B3; }
.numero-card.current { background: var(--ink); color: var(--cream); }
.numero-card.current:hover { background: var(--deep); }

.numero-copertina {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.18;
  pointer-events: none;
  transition: opacity 0.4s ease;
}
.numero-card:hover .numero-copertina { opacity: 0.28; }
.numero-card.current .numero-copertina { opacity: 0.22; }
.numero-card.current:hover .numero-copertina { opacity: 0.35; }

.numero-card-link {
  position: absolute;
  inset: 0;
  z-index: 1;
}
.numero-bg {
  position: absolute;
  top: -1rem; right: -0.5rem;
  font-family: var(--font-display);
  font-size: 9rem;
  font-weight: 900;
  color: rgba(26,20,16,0.06);
  line-height: 1;
  pointer-events: none;
}
.numero-card.current .numero-bg { color: rgba(245,240,232,0.05); }

.numero-label {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  opacity: 0.45;
  margin-bottom: 0.5rem;
  position: relative;
  z-index: 2;
}
.numero-tema {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-style: italic;
  font-weight: 400;
  line-height: 1.2;
  margin-bottom: 0.5rem;
  position: relative;
  z-index: 2;
}
.numero-anno {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  opacity: 0.35;
  margin-bottom: 1.5rem;
  position: relative;
  z-index: 2;
}
.numero-tags {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  flex-wrap: wrap;
  position: relative;
  z-index: 2;
}
.numero-tag {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border: 1px solid var(--rust);
  color: var(--rust);
  padding: 0.25rem 0.6rem;
  text-decoration: none;
}
.numero-card.current .numero-tag {
  border-color: var(--gold);
  color: var(--gold);
}
.numero-tag-pdf {
  border-color: var(--gold) !important;
  color: var(--gold) !important;
  transition: background 0.2s;
}
.numero-tag-pdf:hover { background: rgba(200,169,110,0.15); }

@media (max-width: 900px) {
  .numeri-grid { grid-template-columns: 1fr; }
}
</style>

<div class="container">
  <div class="page-intro">
    <div class="page-intro-number">N°</div>
    <h1 class="page-intro-title">Archivio<br><em>numeri</em></h1>
    <p class="page-intro-desc">Ogni numero esplora un tema attraverso scrittura, illustrazione e fotografia. Un archivio di voci in divenire.</p>
  </div>

  <div class="numeri-grid">
    {% if collections.numeri.length > 0 %}
      {% for numero in collections.numeri %}
        <div class="numero-card reveal {% if loop.first %}current{% endif %}">

          {% if numero.data.copertina %}
            <img src="{{ numero.data.copertina }}"
                 alt="Copertina {{ numero.data.tema }}"
                 class="numero-copertina">
          {% endif %}

          <a href="/numeri/{{ numero.data.slug }}/" class="numero-card-link" aria-label="{{ numero.data.tema }}"></a>

          <div class="numero-bg">{{ numero.data.numero }}</div>
          <div class="numero-label">N° {{ numero.data.numero }}</div>
          <div class="numero-tema">{{ numero.data.tema }}</div>
          <div class="numero-anno">{{ numero.data.anno }}</div>

          <div class="numero-tags">
            {% if loop.first %}
              <div class="numero-tag">Numero corrente</div>
            {% endif %}
            {% if numero.data.pdf %}
              <a href="{{ numero.data.pdf }}" class="numero-tag numero-tag-pdf" target="_blank" rel="noopener">PDF</a>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    {% else %}
      <div class="numero-card current reveal">
        <div class="numero-bg">05</div>
        <div class="numero-label">N° 05</div>
        <div class="numero-tema">Al Bar</div>
        <div class="numero-anno">2025</div>
        <div class="numero-tags"><div class="numero-tag">Numero corrente</div></div>
      </div>
      <div class="numero-card reveal">
        <div class="numero-bg">04</div>
        <div class="numero-label">N° 04</div>
        <div class="numero-tema">Sapore</div>
        <div class="numero-anno">2024</div>
        <div class="numero-tags"></div>
      </div>
      <div class="numero-card reveal">
        <div class="numero-bg">03</div>
        <div class="numero-label">N° 03</div>
        <div class="numero-tema">Apnea</div>
        <div class="numero-anno">2024</div>
        <div class="numero-tags"></div>
      </div>
    {% endif %}
  </div>
</div>
